generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enum-like values
// ---------------------------------------------------------------------------
//
// SQLite stores enum-like fields as strings. App-level validation remains in
// src/lib/types/enums.ts and src/lib/schemas/shared.ts.

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model CandidateListing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Item identity
  marketHashName String
  weaponName     String?
  skinName       String?
  collection     String?
  catalogSkinId  String?
  catalogCollectionId String?
  catalogWeaponDefIndex Int?
  catalogPaintIndex Int?
  rarity         String?
  exterior       String?
  floatValue     Float?
  pattern        Int?
  inspectLink    String?

  // Listing details
  listPrice  Decimal
  currency   String  @default("USD")
  listingUrl String?
  listingId  String?

  // Ingestion metadata
  source     String
  rawPayload Json?

  // Evaluation results
  status              String  @default("WATCHING")
  qualityScore        Float?
  liquidityScore      Float?
  expectedProfit      Decimal?
  expectedProfitPct   Float?
  maxBuyPrice         Decimal?
  matchedPlanId       String?
  marginalBasketValue Decimal?

  // Duplicate tracking
  timesSeen  Int      @default(1)
  mergeCount Int      @default(0)
  lastSeenAt DateTime @default(now())

  // Re-evaluation freshness
  evaluationRefreshedAt DateTime?

  // User pin — when true, evaluateCandidate must not overwrite status.
  pinnedByUser Boolean @default(false)

  // User input
  notes String?

  // Relations
  matchedPlan    TradeupPlan?    @relation(fields: [matchedPlanId], references: [id], onDelete: SetNull)
  inventoryItems InventoryItem[]

  @@index([marketHashName, floatValue])
  @@index([status])
  @@index([matchedPlanId])
  @@index([createdAt])
  @@index([collection])
  @@index([catalogCollectionId, rarity])
  @@index([catalogSkinId])
  @@index([catalogWeaponDefIndex, catalogPaintIndex])
  @@index([rarity])
}

model InventoryItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Item identity
  marketHashName String
  weaponName     String?
  skinName       String?
  collection     String?
  catalogSkinId  String?
  catalogCollectionId String?
  catalogWeaponDefIndex Int?
  catalogPaintIndex Int?
  rarity         String?
  exterior       String?
  floatValue     Float?
  pattern        Int?
  inspectLink    String?

  // Purchase details
  purchasePrice    Decimal
  purchaseCurrency String   @default("USD")
  purchaseFees     Decimal?
  purchaseDate     DateTime @default(now())

  // State
  status       String @default("HELD")
  currentEstValue Decimal?
  notes        String?

  // Link to the live Steam inventory asset id (public inventory JSON), set
  // by the inventory sync action. Unique because a Steam asset is one
  // physical item; multiple operator-tracked rows must not point at the same
  // asset.
  steamAssetId String? @unique

  // Relations
  candidateId String?
  candidate   CandidateListing? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  basketItems TradeupBasketItem[]

  @@index([status])
  @@index([collection, rarity])
  @@index([catalogCollectionId, rarity])
  @@index([catalogSkinId])
  @@index([catalogWeaponDefIndex, catalogPaintIndex])
  @@index([candidateId])
  @@index([marketHashName])
}

model TradeupPlan {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  inputRarity  String
  targetRarity String
  isActive     Boolean @default(true)

  // Thresholds
  minProfitThreshold    Decimal?
  minProfitPctThreshold Float?
  minLiquidityScore     Float?
  minCompositeScore     Float?

  notes String?

  // Relations
  rules             TradeupPlanRule[]
  outcomeItems      TradeupOutcomeItem[]
  baskets           TradeupBasket[]
  executions        TradeupExecution[]
  matchedCandidates CandidateListing[]
  combinations      TradeupCombination[]
}

model TradeupPlanRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planId      String
  collection  String?
  catalogCollectionId String?
  rarity      String?
  exterior    String?
  minFloat    Float?
  maxFloat    Float?
  maxBuyPrice Decimal?
  minQuantity Int?
  maxQuantity Int?
  priority    Int     @default(0)
  isPreferred Boolean @default(false)

  plan TradeupPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([collection, rarity])
  @@index([catalogCollectionId, rarity])
}

model TradeupOutcomeItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planId               String
  marketHashName       String
  weaponName           String?
  skinName             String?
  collection           String
  catalogSkinId        String?
  catalogCollectionId  String?
  catalogWeaponDefIndex Int?
  catalogPaintIndex    Int?
  rarity               String
  estimatedMarketValue Decimal
  probabilityWeight    Float @default(1.0)

  plan TradeupPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([catalogCollectionId, rarity])
  @@index([catalogSkinId])
  @@index([catalogWeaponDefIndex, catalogPaintIndex])
}

model TradeupBasket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planId String
  name   String?
  status String @default("BUILDING")

  // Computed metrics (updated when items change)
  totalCost         Decimal?
  expectedEV        Decimal?
  expectedProfit    Decimal?
  expectedProfitPct Float?
  averageFloat      Float?

  notes String?

  // Relations
  plan      TradeupPlan         @relation(fields: [planId], references: [id])
  items     TradeupBasketItem[]
  execution TradeupExecution?

  @@index([planId])
  @@index([status])
}

model TradeupBasketItem {
  id              String   @id @default(cuid())
  basketId        String
  inventoryItemId String
  slotIndex       Int
  addedAt         DateTime @default(now())

  basket        TradeupBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([basketId, inventoryItemId])
  @@unique([basketId, slotIndex])
  @@index([basketId])
  @@index([inventoryItemId])
}

model TradeupExecution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  basketId   String   @unique
  planId     String
  executedAt DateTime

  // Frozen values at execution time
  inputCost  Decimal
  expectedEV Decimal?

  // Result
  resultMarketHashName String?
  resultWeaponName     String?
  resultSkinName       String?
  resultCollection     String?
  resultExterior       String?
  resultFloatValue     Float?
  estimatedResultValue Decimal?

  // Sale
  salePrice        Decimal?
  saleFees         Decimal?
  saleDate         DateTime?
  realizedProfit   Decimal?
  realizedProfitPct Float?

  notes String?

  // Relations
  basket TradeupBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  plan   TradeupPlan   @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([executedAt])
}

// Saved calculator combinations: a "thesis" snapshot of a tweaked plan +
// 10 specific inputs. Frozen at save time so the original reasoning is
// preserved even when prices or the source plan change. Recheck appends a
// row to TradeupCombinationSnapshot for trend analysis without overwriting
// the thesis.
model TradeupCombination {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  notes    String?
  isActive Boolean @default(false)

  // Mode at save time: 'PLAN' or 'AD_HOC'
  mode String

  // Source plan when saved from a plan-mode calculation. Nullable because
  // ad-hoc combinations have no plan, and PLAN-mode plans may be deleted later.
  sourcePlanId String?
  sourcePlan   TradeupPlan? @relation(fields: [sourcePlanId], references: [id], onDelete: SetNull)

  // Rarities at save time. For PLAN mode these mirror the source plan's
  // rarities at thesis time; for AD_HOC they're the user's choice.
  inputRarity  String
  targetRarity String

  // Frozen "thesis" totals at save time.
  thesisTotalCost         Decimal
  thesisTotalEV           Decimal
  thesisExpectedProfit    Decimal
  thesisExpectedProfitPct Float
  thesisAt                DateTime @default(now())

  // Frozen rule + outcome state so recheck math has a stable comparison
  // even if the source plan was edited or deleted.
  thesisPlanSnapshot Json

  inputs           TradeupCombinationInput[]
  recheckSnapshots TradeupCombinationSnapshot[]

  // External source dedupe — set when the combination was imported from
  // tradeuplab.com via tools/import-tradeuplab.ts. Unique so re-running the
  // importer is idempotent.
  tradeupLabId Int? @unique

  @@index([isActive, createdAt])
  @@index([sourcePlanId])
}

model TradeupCombinationInput {
  id            String @id @default(cuid())
  combinationId String
  slotIndex     Int

  collection          String
  catalogSkinId       String?
  catalogCollectionId String?
  weaponName          String?
  skinName            String?
  floatValue          Float?
  price               Decimal

  combination TradeupCombination @relation(fields: [combinationId], references: [id], onDelete: Cascade)

  @@unique([combinationId, slotIndex])
  @@index([combinationId])
  @@index([catalogSkinId])
  @@index([catalogCollectionId])
}

model TradeupCombinationSnapshot {
  id            String   @id @default(cuid())
  combinationId String
  observedAt    DateTime @default(now())

  totalCost         Decimal
  totalEV           Decimal
  expectedProfit    Decimal
  expectedProfitPct Float

  // Full breakdown so historical views can show per-collection / per-outcome
  // state at the time of the recheck.
  evBreakdown Json?

  combination TradeupCombination @relation(fields: [combinationId], references: [id], onDelete: Cascade)

  @@index([combinationId, observedAt])
}

model MarketPriceObservation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  marketHashName      String
  catalogSkinId       String?
  catalogCollectionId String?
  catalogWeaponDefIndex Int?
  catalogPaintIndex   Int?
  exterior            String?

  currency        String  @default("USD")
  lowestSellPrice Decimal?
  medianSellPrice Decimal?
  volume          Int?
  source          String
  observedAt      DateTime
  rawPayload      Json?

  @@index([marketHashName, currency, observedAt])
  @@index([catalogSkinId, exterior, currency, observedAt])
  @@index([catalogCollectionId, exterior, currency, observedAt])
  @@index([source, observedAt])
}
